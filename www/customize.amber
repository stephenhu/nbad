extends layout

block content
  div.container
    div.row.mt-3
      div.col
        div.list-group.list-group-horizontal
          div.list-group-item.active
            div feb 12
          div.list-group-item
            a.list-group-item-action[href=""]
              div nyk
                span.score 86
              div bos
                span.score 113
          div.list-group-item
            a.list-group-item-action[href=""]
              div nyk
                span.score 86
              div bos
                span.score 113
