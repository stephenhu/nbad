          li.list-group-item
            div ATL
              span.score 115
            div TOR
              span.score 131
        br
        br
    div.row
      div.col-4
        div.list-group
          a.list-group-item.list-group-item-action[href=""]
            div.media
              img.mr-3[src="/www/202710.png"][width="132"]
              div.media-body            
                h5.mb-0.electric-blue Jimmy Butler
                div PER 20.0
                div PPG 25.7
            i.fas.fa-caret-down.fa-5x
          br
