extends layout

block content
  div.container
    div.row
      div.col
        ul.list-group.list-group-horizontal
          li.list-group-item
            div NYK
              span.score 86
            div BOS
              span.score 113
          li.list-group-item
            div LAC
              span.score 120
            div SAS
              span.score 102
          li.list-group-item
            div SAC
              span.score 99
            div DAL
              span.score 105
          li.list-group-item
            div ATL
              span.score 115
            div TOR
              span.score 131
